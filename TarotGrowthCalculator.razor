@page "/tarot"

<PageTitle>Tarot Growth Number</PageTitle>

<style>
    /* ── Google Fonts ── */
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:ital,wght@0,600;1,400&display=swap');

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    .tarot-root {
        font-family: 'Inter', sans-serif;
        min-height: 100vh;
        background: linear-gradient(160deg, #f5f0e8 0%, #eef2fb 50%, #f5f0e8 100%);
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 0 16px 80px;
    }

    /* ── HEADER ── */
    .tarot-header {
        width: 100%;
        max-width: 680px;
        text-align: center;
        padding: 72px 0 40px;
    }
    .tarot-header .eyebrow {
        font-size: 11px;
        font-weight: 600;
        letter-spacing: 3px;
        text-transform: uppercase;
        color: #b8982a;
        margin-bottom: 16px;
    }
    .tarot-header h1 {
        font-family: 'Playfair Display', serif;
        font-size: clamp(36px, 6vw, 56px);
        font-weight: 600;
        color: #1a2340;
        line-height: 1.15;
        margin-bottom: 16px;
    }
    .tarot-header h1 span {
        font-style: italic;
        color: #b8982a;
    }
    .tarot-header p {
        font-size: 16px;
        color: #556;
        line-height: 1.7;
        font-weight: 400;
    }

    /* ── DIVIDER ── */
    .ornament {
        display: flex;
        align-items: center;
        gap: 12px;
        margin: 0 auto 40px;
        width: 200px;
        color: #c8a84b;
        font-size: 18px;
    }
    .ornament::before, .ornament::after {
        content: '';
        flex: 1;
        height: 1px;
        background: linear-gradient(90deg, transparent, #c8a84b);
    }
    .ornament::after { background: linear-gradient(90deg, #c8a84b, transparent); }

    /* ── INPUT CARD ── */
    .input-card {
        width: 100%;
        max-width: 480px;
        background: rgba(255,255,255,0.85);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border: 1px solid rgba(255,255,255,0.9);
        border-radius: 28px;
        padding: 40px 40px 36px;
        box-shadow: 0 8px 40px rgba(26,35,64,0.10), 0 2px 8px rgba(26,35,64,0.06);
        margin-bottom: 32px;
    }
    .input-label {
        display: block;
        font-size: 12px;
        font-weight: 600;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        color: #8890aa;
        margin-bottom: 12px;
    }
    .date-input {
        width: 100%;
        padding: 16px 20px;
        font-family: 'Inter', sans-serif;
        font-size: 17px;
        font-weight: 500;
        color: #1a2340;
        background: #f3f5fb;
        border: 1.5px solid transparent;
        border-radius: 16px;
        outline: none;
        transition: border-color .25s, box-shadow .25s, background .25s;
        cursor: pointer;
        appearance: none;
        -webkit-appearance: none;
    }
    .date-input:focus {
        border-color: #c8a84b;
        background: #fff;
        box-shadow: 0 0 0 4px rgba(200,168,75,0.15);
    }
    .date-input::-webkit-calendar-picker-indicator {
        opacity: 0.5;
        cursor: pointer;
    }

    .calc-btn {
        margin-top: 24px;
        width: 100%;
        padding: 18px 24px;
        font-family: 'Inter', sans-serif;
        font-size: 15px;
        font-weight: 600;
        letter-spacing: .5px;
        color: #fff;
        background: linear-gradient(135deg, #c8a84b 0%, #a07820 100%);
        border: none;
        border-radius: 16px;
        cursor: pointer;
        transition: transform .18s, box-shadow .18s, opacity .18s;
        box-shadow: 0 4px 20px rgba(160,120,32,0.35);
    }
    .calc-btn:hover:not(:disabled) {
        transform: translateY(-2px);
        box-shadow: 0 8px 28px rgba(160,120,32,0.42);
    }
    .calc-btn:active:not(:disabled) { transform: translateY(0); }
    .calc-btn:disabled { opacity: .5; cursor: not-allowed; }

    .error-msg {
        margin-top: 14px;
        font-size: 13px;
        color: #c0392b;
        text-align: center;
    }

    /* ── RESULT CARD ── */
    .result-card {
        width: 100%;
        max-width: 480px;
        background: rgba(255,255,255,0.92);
        backdrop-filter: blur(24px);
        -webkit-backdrop-filter: blur(24px);
        border: 1px solid rgba(255,255,255,0.95);
        border-radius: 28px;
        padding: 0;
        box-shadow: 0 16px 60px rgba(26,35,64,0.14), 0 2px 8px rgba(26,35,64,0.06);
        overflow: hidden;
        animation: slideUp .45s cubic-bezier(.16,1,.3,1) both;
    }
    @@keyframes slideUp {
        from { opacity:0; transform: translateY(32px); }
        to   { opacity:1; transform: translateY(0); }
    }

    .result-banner {
        background: linear-gradient(135deg, #1a2340 0%, #253060 100%);
        padding: 36px 40px 30px;
        text-align: center;
        position: relative;
        overflow: hidden;
    }
    .result-banner::before {
        content: '';
        position: absolute; inset: 0;
        background: radial-gradient(ellipse at top right, rgba(200,168,75,.25), transparent 65%);
        pointer-events: none;
    }
    .number-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 72px; height: 72px;
        border-radius: 50%;
        background: linear-gradient(135deg, #c8a84b, #e6c96a);
        font-family: 'Playfair Display', serif;
        font-size: 30px;
        font-weight: 600;
        color: #1a2340;
        margin-bottom: 18px;
        box-shadow: 0 4px 24px rgba(200,168,75,.55);
    }
    .arcana-name {
        font-family: 'Playfair Display', serif;
        font-size: 28px;
        font-weight: 600;
        color: #fff;
        margin-bottom: 6px;
    }
    .arcana-roman {
        font-size: 13px;
        font-weight: 500;
        letter-spacing: 3px;
        text-transform: uppercase;
        color: #c8a84b;
    }

    .result-body {
        padding: 32px 40px 36px;
    }
    .calc-trail {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        font-size: 13px;
        color: #8890aa;
        margin-bottom: 28px;
        flex-wrap: wrap;
    }
    .trail-chip {
        background: #f0f3fa;
        border-radius: 100px;
        padding: 5px 12px;
        font-weight: 500;
        color: #556;
    }
    .trail-arrow { color: #c8a84b; font-size: 16px; }

    .section-label {
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 2.5px;
        text-transform: uppercase;
        color: #c8a84b;
        margin-bottom: 12px;
    }
    .interpretation {
        font-size: 15px;
        line-height: 1.8;
        color: #2c3554;
        font-weight: 400;
        border-left: 3px solid #c8a84b;
        padding-left: 16px;
    }

    .keywords {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin-top: 24px;
    }
    .kw-chip {
        font-size: 12px;
        font-weight: 500;
        color: #1a2340;
        background: linear-gradient(135deg, #f9f4e8, #f3ecd8);
        border: 1px solid #e0c97a;
        border-radius: 100px;
        padding: 5px 14px;
    }

    .reset-btn {
        display: block;
        margin: 28px auto 0;
        padding: 12px 32px;
        font-family: 'Inter', sans-serif;
        font-size: 13px;
        font-weight: 600;
        letter-spacing: .5px;
        color: #8890aa;
        background: transparent;
        border: 1.5px solid #dde0ea;
        border-radius: 100px;
        cursor: pointer;
        transition: color .2s, border-color .2s;
    }
    .reset-btn:hover { color: #1a2340; border-color: #1a2340; }
</style>

<div class="tarot-root">

    <!-- HEADER -->
    <header class="tarot-header">
        <div class="eyebrow">Major Arcana · Growth Number</div>
        <h1>Discover Your<br /><span>Tarot Path</span></h1>
        <p>Enter your birthdate to reveal the Major Arcana card<br />that guides your soul's growth journey.</p>
    </header>

    <div class="ornament">✦</div>

    <!-- INPUT CARD -->
    <div class="input-card">
        <label class="input-label" for="birthdate">Your Date of Birth</label>
        <input id="birthdate"
               class="date-input"
               type="date"
               @bind="birthdate"
               max="@DateTime.Today.ToString("yyyy-MM-dd")" />

        <button class="calc-btn"
                @onclick="Calculate"
                disabled="@(!birthdate.HasValue)">
            Reveal My Card ✦
        </button>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <p class="error-msg">@errorMessage</p>
        }
    </div>

    <!-- RESULT CARD -->
    @if (result is not null)
    {
        <div class="result-card">
            <div class="result-banner">
                <div class="number-badge">@result.Number</div>
                <div class="arcana-name">@result.CardName</div>
                <div class="arcana-roman">@result.RomanNumeral &nbsp;·&nbsp; Major Arcana</div>
            </div>

            <div class="result-body">
                <!-- Calculation trail -->
                <div class="calc-trail">
                    @foreach (var (chip, idx) in trailChips.Select((c, i) => (c, i)))
                    {
                        @if (idx > 0) { <span class="trail-arrow">→</span> }
                        <span class="trail-chip">@chip</span>
                    }
                    <span class="trail-arrow">→</span>
                    <span class="trail-chip" style="background:#1a2340;color:#c8a84b;font-weight:700;">@result.Number</span>
                </div>

                <!-- Interpretation -->
                <div class="section-label">Interpretation</div>
                <p class="interpretation">@result.Interpretation</p>

                <!-- Keywords -->
                <div class="keywords">
                    @foreach (var kw in result.Keywords)
                    {
                        <span class="kw-chip">@kw</span>
                    }
                </div>

                <button class="reset-btn" @onclick="Reset">← Try Another Date</button>
            </div>
        </div>
    }

</div>

@code {
    private DateTime? birthdate;
    private string errorMessage = "";
    private TarotResult? result;
    private List<string> trailChips = new();

    private void Calculate()
    {
        errorMessage = "";
        result = null;
        trailChips.Clear();

        if (!birthdate.HasValue) return;

        // 날짜 숫자 추출 (YYYYMMDD 형식)
        string digits = birthdate.Value.ToString("yyyyMMdd");
        int sum = digits.Sum(c => c - '0');
        trailChips.Add(digits);
        trailChips.Add(sum.ToString());

        // 22 이하가 될 때까지 자릿수 합산
        while (sum > 22)
        {
            int next = sum.ToString().Sum(c => c - '0');
            trailChips.Add(next.ToString());
            sum = next;
        }

        result = GetTarotResult(sum);
    }

    private void Reset()
    {
        result = null;
        trailChips.Clear();
        errorMessage = "";
    }

    // ────────────────────────────────────────────────
    // Major Arcana 데이터
    // ────────────────────────────────────────────────
    private static TarotResult GetTarotResult(int n) => n switch
    {
        1  => new(1,  "The Magician",      "I",      "당신은 타고난 현현자입니다. 우주는 생각을 현실로 바꾸는 힘을 당신에게 선물했습니다. 성장의 열쇠는 집중력과 의도를 갈고닦는 데 있습니다. 필요한 모든 도구는 이미 당신의 손 안에 있습니다.", new[]{"의지력","현현","기술","주도성"}),
        2  => new(2,  "The High Priestess","II",     "직관이 당신의 가장 위대한 나침반입니다. 세상의 소음보다 조용한 내면의 목소리를 신뢰할 때 진정한 성장이 찾아옵니다. 고요함은 분석이 결코 보여주지 못하는 것을 드러냅니다.", new[]{"직관","신비","인내","내면의 앎"}),
        3  => new(3,  "The Empress",       "III",    "풍요는 당신의 타고난 권리입니다. 자연, 관계, 창조적 활동을 돌보는 과정에서 성장이 피어납니다. 베푸는 만큼 받아들이는 것도 허락하세요.", new[]{"창의성","풍요","넉넉함","돌봄"}),
        4  => new(4,  "The Emperor",       "IV",     "구조는 감옥이 아니라 당신이 이끄는 왕좌입니다. 성장의 길은 지속되는 기반을 쌓고, 책임을 받아들이며, 지혜롭게 야망을 이끄는 데 있습니다.", new[]{"권위","구조","안정","리더십"}),
        5  => new(5,  "The Hierophant",    "V",      "당신은 더 깊은 의미를 추구하는 구도자입니다. 전통, 스승의 가르침, 영적 탐구를 통해 성장이 펼쳐집니다. 세대를 거쳐 전해 내려온 지혜 속에 당신이 찾던 열쇠가 있습니다.", new[]{"전통","안내","믿음","공동체"}),
        6  => new(6,  "The Lovers",        "VI",     "영혼은 연결과 선택을 통해 성장합니다. 관계는 당신의 가장 위대한 스승입니다. 순간적인 욕망이 아닌 가장 깊은 가치에 맞게 결정을 내릴 때 진정한 성장이 찾아옵니다.", new[]{"관계","일치","선택","조화"}),
        7  => new(7,  "The Chariot",       "VII",    "승리는 내면의 모순을 다스리는 자에게 찾아옵니다. 대립하는 힘을 앞으로 나아가는 추진력으로 전환할 때 성장합니다. 규율과 결단이 바로 당신의 전차입니다.", new[]{"결단력","통제","승리","집중"}),
        8  => new(8,  "Strength",          "VIII",   "부드러운 끈기가 거친 힘을 이깁니다. 성장 카드는 연민과 조용한 용기가 공격성보다 강하다는 것을 일깨워 줍니다. 두려움이 아닌 사랑으로 내면의 사자를 길들이세요.", new[]{"용기","인내","연민","내면의 힘"}),
        9  => new(9,  "The Hermit",        "IX",     "고독은 당신에게 신성한 시간입니다. 가장 깊은 성장은 조용한 성찰 속에서 자신만의 진실의 등불을 찾을 때 이루어집니다. 그 빛을 찾았다면 어둠 속을 걷는 이들과 나누세요.", new[]{"성찰","지혜","고독","내면의 안내"}),
        10 => new(10, "Wheel of Fortune",  "X",      "변화는 유일한 상수이자 당신의 스승입니다. 삶의 순환을 평정심으로 받아들일 때 성장합니다. 오르는 것은 반드시 내려가고, 내려간 것은 반드시 다시 오릅니다.", new[]{"변화","순환","행운","운명"}),
        11 => new(11, "Justice",           "XI",     "인과율이 당신의 길을 다스립니다. 성장은 성실함, 공정함, 책임감에 뿌리를 둡니다. 당신의 모든 선택은 생각보다 멀리 울려 퍼집니다. 맑은 눈으로 결정하세요.", new[]{"공정","진실","책임","균형"}),
        12 => new(12, "The Hanged Man",    "XII",    "내려놓음은 패배가 아니라 계시로 향하는 관문입니다. 통제를 내려놓고 시각을 전환하며 멈춤 속에서 은혜를 찾을 때 성장합니다. 기다림처럼 보이는 것이 사실은 변화입니다.", new[]{"내려놓음","관점","멈춤","희생"}),
        13 => new(13, "Death",             "XIII",   "끝맺음은 신성한 새 시작입니다. 성장 숫자는 근본적인 변환을 요청합니다. 더 이상 도움이 되지 않는 것을 내려놓아야 운명이 들어올 공간이 열립니다. 변화는 당신의 가장 강력한 동반자입니다.", new[]{"변환","끝맺음","재생","전환"}),
        14 => new(14, "Temperance",        "XIV",    "연금술이 당신 영혼 안에 살고 있습니다. 인내와 열정, 논리와 직관 같은 반대되는 것들을 아름다운 균형으로 조화시킬 때 성장합니다. 절제가 바로 당신의 초능력입니다.", new[]{"균형","절제","연금술","목적"}),
        15 => new(15, "The Devil",         "XV",     "해방이 당신을 부르고 있습니다. 성장의 길은 자신의 그림자를 솔직하게 마주하고 건강하지 않은 집착을 내려놓는 것을 요구합니다. 보이는 사슬은 대부분 스스로 풀 수 있는 것들입니다.", new[]{"그림자 작업","자각","해방","정직"}),
        16 => new(16, "The Tower",         "XVI",    "갑작스러운 각성이 당신의 세계를 재편합니다. 성장은 혼란 속에서 찾아옵니다. 환상의 탑이 무너져야 단단한 땅이 드러납니다. 붕괴 속에 있는 돌파구를 끌어안으세요.", new[]{"격변","계시","돌파","변화"}),
        17 => new(17, "The Star",          "XVII",   "희망이 당신의 초능력입니다. 어떤 폭풍이 지나간 후에도 재생과 빛나는 믿음을 되찾습니다. 성장은 우주의 계획을 신뢰하고 진정한 빛을 세상에 자유롭게 쏟아내는 것입니다.", new[]{"희망","재생","영감","평온"}),
        18 => new(18, "The Moon",          "XVIII",  "무의식이 당신의 바다입니다. 가장 깊은 성장은 꿈, 상징, 정신의 어두운 깊이를 탐험하는 데서 옵니다. 두려움을 마주하세요. 두려움은 지혜로 가는 문입니다.", new[]{"환상","직관","꿈","무의식"}),
        19 => new(19, "The Sun",           "XIX",    "빛남, 기쁨, 활력이 당신의 길을 수놓습니다. 성장은 진정한 자기 표현의 외적 확장입니다. 사과 없이 빛날수록 주변 세계를 더욱 환하게 밝힙니다.", new[]{"기쁨","성공","활력","명료함"}),
